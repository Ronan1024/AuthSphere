<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.authsphere.server.realm.mapper.RealmTypeMapper">

    <resultMap id="BaseResultMap" type="com.authsphere.server.realm.model.RealmType">
            <id property="id" column="id" jdbcType="BIGINT"/>
            <result property="code" column="code" jdbcType="VARCHAR"/>
            <result property="name" column="name" jdbcType="VARCHAR"/>
            <result property="description" column="description" jdbcType="VARCHAR"/>
            <result property="systemBuiltin" column="system_builtin" jdbcType="TINYINT"/>
            <result property="editable" column="editable" jdbcType="TINYINT"/>
            <result property="status" column="status" jdbcType="TINYINT"/>
            <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
            <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,code,name,
        description,system_builtin,editable,
        status,create_time,update_time
    </sql>

    <select id="page" resultType="com.authsphere.server.realm.dto.RealmTypePageResponse">
        select
            id,
            code,
            name,
            description,
            system_builtin as systemBuiltin,
            editable,
            status,
            create_time,
            update_time
        from realm_type
        <where>
            <if test="request.name != null and request.name != ''">
                and `name` like concat('%', #{request.name}, '%')
            </if>
            <if test="request.code != null and request.code != ''">
                and `code` = #{request.code}
            </if>
            <if test="request.status != null">
                and `status` = #{request.status}
            </if>
        </where>
        order by create_time desc
    </select>

    <select id="listAll" resultType="com.authsphere.server.realm.dto.RealmTypePageResponse">
        select
            id,
            code,
            name,
            description,
            system_builtin as systemBuiltin,
            editable,
            status,
            create_time,
            update_time
        from realm_type
        where status = 1
        order by create_time desc
    </select>

</mapper>
